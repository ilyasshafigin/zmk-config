ZMK_LAYER(cmd,
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮   ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
    &bootloader     &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_CLR          &out OUT_TOG    _ C_VOL_DN      _ C_VOL_UP      _ C_MUTE        &bootloader
// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    &sys_reset      XXX             _ SPACE_P       _ SPACE_N       &tabber             _ SPACE_U       _ C_PREV        _ C_NEXT        _ C_PP          &sys_reset
