#include <dt-bindings/zmk/pointing.h>
#include <behaviors/brightness.dtsi>
#include "includes/behaviors.dtsi"
#include "includes/keys.h"
#include "includes/layers.h"
#include "zmk-helpers/key-labels/36.h"

/*
  ╭─────────────────────┬─────────────────────╮
  │ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
  │ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 │
  │ LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 │
  ╰───────╮ LH2 LH1 LH0 │ RH0 RH1 ╭───────────╯
          ╰─────────────┴─────────╯
*/

MAKE_HRM(hml,   &kp, &kp,   KEYS_R THUMBS)
MAKE_HRM(hmr,   &kp, &kp,   KEYS_L THUMBS)

ZMK_SMART_TOGGLE(tabber,
    bindings = <&kp LCTRL>, <&kp TAB>;
    ignored-key-positions = <LM0 LH1>;
)

ZMK_SMART_TOGGLE(swapper,
    bindings = <&kp LGUI>, <&kp TAB>;
    ignored-key-positions = <LB0 LH1>;
)

// hold - mo layer, tap - to layer
ZMK_HOLD_TAP(ht_two,
    bindings = <&mo>, <&to>; // hold, tap
    flavor = "balanced";
    tapping-term-ms = <TAPPING_TERM_FAST_MS>;
)

// hold - MSE, tap - to DEF, double tap - tog MSE
ZMK_TAP_DANCE(td_mse,
    bindings = <&ht_two MSE DEF>, <&tog MSE>;
    tapping-term-ms = <TAPPING_TERM_FAST_MS>;
)

ZMK_COMBO(para_left,      &kp UL_LPAR,    LT1 LT0,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(para_right,     &kp UL_RPAR,    RT0 RT1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(brak_left,      &kp UL_LBKT,    LM1 LM0,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(brak_right,     &kp UL_RBKT,    RM0 RM1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(brace_left,     &kp UL_LBRC,    LB1 LB0,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(brace_right,    &kp UL_RBRC,    RB0 RB1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(single_quote,   &kp UL_SQT,     LB2 LB1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(double_quote,   &kp UL_DQT,     RB1 RB2,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(grave,          &kp UL_GRAVE,   LT2 LT1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(tilde,          &kp UL_TILDE,   RT1 RT2,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(backslash,      &kp UL_BSLH,    LM3 LM2,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(slash,          &kp UL_FSLH,    RM2 RM3,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(arrow,          &kp UL_ARROW,   LT3 LT2,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(double_arrow,   &kp UL_DARROW,  RT2 RT3,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(lang_ru,        &kp LANG_RU,    LM2 LM1,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(lang_en,        &kp LANG_EN,    RM1 RM2,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(layer_game,     &tog GAM,       RT3 RT4,    DEF,      COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(esc,            &kp ESC,        LT4 LT3,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
//ZMK_COMBO(tab,            &kp TAB,        LM4 LM3,    DEF SYM,  COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(left_click_l,   &mkp LCLK,      LB2 LB1,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(left_click_r,   &mkp LCLK,      RB2 RB1,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(right_click_l,  &mkp RCLK,      LB3 LB2,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(right_click_r,  &mkp RCLK,      RB3 RB2,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(middle_click_l, &mkp MCLK,      LM3 LM2,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)
ZMK_COMBO(middle_click_r, &mkp MCLK,      RM3 RM2,    DEF SYM NAV MSE SLOW SCRL CARE, COMBO_TERM, COMBO_IDLE)

/**
 * Default Layer - QWERTY
 */
ZMK_LAYER(base,
// ╭────────────────┬────────────────┬────────────────┬────────────────┬───────────────╮   ╭───────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
// │            Q Й │            W Ц │            E У │            R К │           T Е │   │           Y Н │            U Г │            I Ш │            O З │            P Х │
    _ Q              _ W              _ E              _ R              _ T                 _ Y             _ U              _ I              _ O              _ P
// ├────────────────┼────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
// │ GUI        A Ф │ ALT        S Ы │ CTRL       D В │ SHIFT      F А │           G П │   │           H Р │ SHIFT      J О │ CTRL       K Л │ ALT        L Д │ GUI        ~ Ж │
    &hml LGUI A      &hml LALT S      &hml LCTRL D     &hml LSHFT F     _ G                 _ H             &hmr LSHFT J     &hmr LCTRL K     &hmr LALT L      &hmr LGUI UL_TILDE
// ├────────────────┼────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
// │            Z Я │            X Ч │            C С │            V М │           B И │   │           N Т │            M Ь │            & Б │            [ Ю │            ] Э │
    _ Z              &lt CARE X       &lt SCRL C       &lt SLOW V       _ B                 _ N             &lt SLOW M       &lt SCRL UL_AMPS &lt CARE UL_LBKT _ UL_RBKT
// ╰────────────────┴────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┴────────────────┴────────────────╯
//                                   │                │                │               │   │               │                │
                                      &td_mse          &mt LSHFT SPACE  &mo NAV             &mo SYM         &lt CMD BSPC
//                                   ╰────────────────┴────────────────┴───────────────╯   ╰───────────────┴────────────────╯
)

/**
 * SYM Layer
 */
ZMK_LAYER(symbol,
// ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬───────────────╮   ╭───────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────╮
// │                ^ │                @ │                # │                $ │             ( │   │             ) │                ? │                ! │                * │                % │
    _ UL_CARET         _ UL_AT            _ UL_HASH          _ UL_DLLR          _ UL_LPAR           _ UL_RPAR       _ UL_QSTM          _ UL_EXCL          _ UL_ASTRK         _ UL_PRCNT
// ├──────────────────┼──────────────────┼──────────────────┼──────────────────┼───────────────┤   ├───────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
// │ GUI          ~ Ж │ ALT            ` │ CTRL           ' │ SHIFT          " │             [ │   │             ] │ SHIFT          . │ CTRL           : │ ALT            + │ GUI            = │
    &hml LGUI UL_TILDE &hml LALT UL_GRAVE &hml LCTRL UL_SQT  &hml LSHFT UL_DQT  _ LA(UL_LBKT)       _ LA(UL_RBKT)   &hmr LSHFT UL_DOT  &hmr LCTRL UL_COLON &hmr LALT UL_PLUS &hmr LGUI UL_EQUAL
// ├──────────────────┼──────────────────┼──────────────────┼──────────────────┼───────────────┤   ├───────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
// │               -> │                | │                \ │                / │             { │   │             } │                , │                ; │                - │                _ │
    _ UL_ARROW         _ UL_PIPE          _ UL_BSLH          _ UL_FSLH          _ LA(UL_LBRC)       _ LA(UL_RBRC)   _ UL_COMMA         _ UL_SEMI          _ UL_MINUS         _ UL_UNDER
// ╰──────────────────┴──────────────────┼──────────────────┼──────────────────┼───────────────┤   ├───────────────┼──────────────────┼──────────────────┴──────────────────┴──────────────────╯
//                                       │                  │                  │               │   │               │                  │
                                          XXX                &mt LSHFT UL_NBSP  &mo NUM             ___             &mo ALT
//                                       ╰──────────────────┴──────────────────┴───────────────╯   ╰───────────────┴──────────────────╯
)

/**
 * NAV Layer
 */
ZMK_LAYER(nav,
// ╭────────────────┬────────────────┬────────────────┬────────────────┬───────────────╮   ╭───────────────┬────────────────┬────────────────┬────────────────┬───────────────╮
    _ UL_COMMA       _ UL_N7          _ UL_N8          _ UL_N9          _ ESC               _ BSPC          _ HOME           _ END            XXX              &tog GAM
// ├────────────────┼────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┼────────────────┼───────────────┤
    &hml LGUI UL_DOT &hml LALT UL_N4  &hml LCTRL UL_N5 &hml LSHFT UL_N6 _ TAB               _ DEL           &hmr LSHFT LEFT  &hmr LCTRL DOWN  &hmr LALT UP     &hmr LGUI RIGHT
// ├────────────────┼────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┼────────────────┼───────────────┼
    _ UL_N0          _ UL_N1          _ UL_N2          _ UL_N3          _ ENTER             _ ENTER         _ PG_UP          _ PG_DN          _ APOS           &caps_word
// ╰────────────────┴────────────────┼────────────────┼────────────────┼───────────────┤   ├───────────────┼────────────────┼────────────────┴────────────────┴───────────────╯
                                      XXX              &mt LSHFT SPACE  ___                 &mo NUM         _ BSPC
//                                   ╰────────────────┴────────────────┴───────────────╯   ╰───────────────┴────────────────╯
)

/**
 * NUM Layer
 */
ZMK_LAYER(num,
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮   ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
    _ KP_COMMA      _ KP_N7         _ KP_N8         _ KP_N9         _ KP_NLCK           _ F10           _ F9            _ F8            _ F7            _ F13
// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    &hml LGUI KP_DOT &hml LALT KP_N4 &hml LCTRL KP_N5 &hml LSHFT KP_N6 XXX              _ F11           &hmr LSHFT F6   &hmr LCTRL F5   &hmr LALT F4    &hmr LGUI F14
// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    _ KP_N0         _ KP_N1         _ KP_N2         _ KP_N3         _ KP_ENTER          _ F12           _ F3            _ F2            _ F1            _ F15
// ╰───────────────┴───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┴───────────────┴───────────────╯
                                    XXX             &mt LSHFT SPACE ___                 ___             _ BSPC
//                                 ╰───────────────┴───────────────┴───────────────╯   ╰───────────────┴───────────────╯
)

/**
 * ALT Layer
 */
ZMK_LAYER(alt,
// ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮   ╭───────────────┬───────────────┬───────────────┬───────────────┬───────────────╮
    _ RA(Q)         _ RA(W)         _ RA(E)         _ RA(R)         _ RA(T)             _ RA(Y)         _ RA(U)         _ RA(I)         _ RA(O)         _ RA(P)
// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    _ RA(A)         _ RA(S)         _ RA(D)         _ RA(F)         _ RA(G)             _ RA(H)         _ RA(J)         _ RA(K)         _ RA(L)         _ RA(UL_TILDE)
// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    _ RA(Z)         _ RA(X)         _ RA(C)         _ RA(V)         _ RA(B)             _ RA(N)         _ RA(M)         _ RA(UL_AMPS)   _ RA(UL_LBKT)   _ RA(UL_RBKT)
// ╰───────────────┴───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┴───────────────┴───────────────╯
                                    XXX             &mt LSHFT UL_NBSP XXX               ___             ___
//                                 ╰───────────────┴───────────────┴───────────────╯   ╰───────────────┴───────────────╯
)

/**
 * CMD Layer
