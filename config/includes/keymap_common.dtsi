// ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤   ├───────────────┼───────────────┼───────────────┼───────────────┼───────────────┤
    XXX,            &dec_bri,       &inc_bri,       XXX,            &swapper,           _ SPACE_D,      _ C_BRI_DN,     _ C_BRI_UP,     XXX,            &soft_off,
